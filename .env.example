# Copy to `.env` and fill in the providers you want to use.
# At least one of {Microsoft, Google} must be configured. Leave the other
# block blank to disable that provider on the login page.
#
# ── MICROSOFT (Outlook.com) ──────────────────────────────────────────────
# Register at https://entra.microsoft.com -> Applications -> App registrations:
#   * Supported account types: "Personal Microsoft accounts only"
#   * Platform: Web
#   * Redirect URI: http://localhost:8080/auth/microsoft/callback
#   * Certificates & secrets -> create a client secret
#   * API permissions -> Microsoft Graph -> Delegated:
#       Mail.ReadWrite, offline_access  (no admin consent needed for MSA)

CLIENT_ID=
CLIENT_SECRET=
AUTHORITY=https://login.microsoftonline.com/consumers
REDIRECT_URI=http://localhost:8080/auth/microsoft/callback

# ── GOOGLE (Gmail) ───────────────────────────────────────────────────────
# Register at https://console.cloud.google.com:
#   1. Create a project, then "OAuth consent screen" -> External -> Testing.
#   2. Add yourself as a test user. (Personal/testing mode means no Google
#      verification process is needed for sensitive scopes.)
#   3. "Credentials" -> Create OAuth client ID -> Web application.
#   4. Authorized redirect URI: http://localhost:8080/auth/google/callback
#   5. Add scope: https://www.googleapis.com/auth/gmail.modify
#   6. Enable the "Gmail API" under APIs & Services.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=replace-with-random-bytes

# Optional: separate key for encrypting the per-user token cache at rest.
# When set, you can rotate SESSION_SECRET without invalidating stored tokens
# (otherwise SESSION_SECRET does double duty and rotating it forces every
# user to re-sign in). Generate with the same one-liner above.
CACHE_KEY=

# Ollama for spam classification. The agent posts each fetched message
# (sender, subject, preview) to {OLLAMA_URL}/api/generate with format=json.
# On macOS / Windows Docker Desktop, host.docker.internal resolves to the
# host. On Linux, replace with the host IP or a container on the same network.
# Pull the model first:  ollama pull llama3.2
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_CONCURRENCY=4

# Ollama generation parameters (passed in `options` on /api/generate).
#   num_ctx       — context window. Each prompt is ~200-300 tokens, so 1024
#                   gives ~3-4x headroom. Larger wastes RAM/VRAM, smaller risks
#                   truncation on long subjects.
#   temperature   — 0.0 makes classification deterministic (same email → same
#                   verdict). Raise only if you want the model to be creative,
#                   which is generally not what you want for spam classification.
#   num_predict   — max output tokens. The JSON verdict is well under 100,
#                   so 200 is a safe cap that prevents runaway generations.
OLLAMA_NUM_CTX=1024
OLLAMA_TEMPERATURE=0.0
OLLAMA_NUM_PREDICT=200

# Few-shot examples drawn from the user's past audits (rules applied + manual
# deletes/unsubscribes). The audit prompt prepends N spam + N ham examples
# so the model calibrates to this user's taste.
#   - Each example is ~80 tokens; default 3+3 = 480 tokens leaves headroom
#     under num_ctx=1024 (after system prompt + target message).
#   - Increase carefully: with num_ctx=1024 you'll cap out around 4. To go
#     higher, raise num_ctx too (e.g. 2048 → safe up to ~12).
#   - Set to 0 to disable few-shot entirely.
OLLAMA_EXAMPLES_PER_CLASS=3

# Maximum messages per audit run. The agent paginates Graph's @odata.nextLink
# up to this cap. Each surviving message is sent to Ollama, so audit time
# scales linearly: at concurrency 4 with ~3s per Ollama call, 200 messages ≈ 150s.
MAX_MESSAGES_PER_AUDIT=200

# Comma-separated sender domains whose mail is auto-deleted before classification.
# Subdomain matching is enabled — listing "example.com" also blocks "mail.example.com".
# Leave empty to disable. Uses the same Mail.ReadWrite scope as the manual Delete button.
BLOCKED_DOMAINS=

# Proactive rule suggestions: surface a banner on the home page when a sender
# accumulates this many manual deletes + unsubscribes. Set to a higher number
# for less noise, lower for more eager suggestions.
SUGGEST_BLOCK_THRESHOLD=3
SUGGEST_MAX_ITEMS=5

# Scheduler (auto-runs audits in the background).
#   DEFAULT_SCHEDULE_INTERVAL_MINUTES — fallback interval applied to any user
#       who hasn't set their own override on /ui/settings. Leave blank to
#       disable scheduling globally; per-user values still take precedence.
#       Examples: 15 (every 15 min), 60 (hourly), 360 (every 6h).
#   SCHEDULER_TICK_SECONDS — how often the scheduler wakes to check whether
#       any user is due. 60s is fine; lower it for sub-minute precision.
DEFAULT_SCHEDULE_INTERVAL_MINUTES=
SCHEDULER_TICK_SECONDS=60
