# Copy to `.env` and fill in values from your app registration.
#
# In https://entra.microsoft.com -> Applications -> App registrations -> New:
#   * Supported account types: "Personal Microsoft accounts only"
#   * Platform: Web
#   * Redirect URI: http://localhost:8080/auth/callback
# Under "Certificates & secrets" -> create a client secret.
# Under "API permissions" -> Microsoft Graph -> Delegated:
#   Mail.ReadWrite, offline_access
#   (no admin consent needed for personal Microsoft accounts)
# Mail.ReadWrite is needed because the agent moves spam-flagged messages to
# Deleted Items via DELETE /me/messages/{id}. It implies Mail.Read.
#
# Refresh-token lifetime for personal accounts is governed by Microsoft (not
# tunable via TokenLifetimePolicy). Plan tasks for hours-to-low-days, not weeks.

CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=replace-with-secret
AUTHORITY=https://login.microsoftonline.com/consumers
REDIRECT_URI=http://localhost:8080/auth/callback

# Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=replace-with-random-bytes

# Ollama for spam classification. The agent posts each fetched message
# (sender, subject, preview) to {OLLAMA_URL}/api/generate with format=json.
# On macOS / Windows Docker Desktop, host.docker.internal resolves to the
# host. On Linux, replace with the host IP or a container on the same network.
# Pull the model first:  ollama pull llama3.2
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_CONCURRENCY=4

# Ollama generation parameters (passed in `options` on /api/generate).
#   num_ctx       — context window. Each prompt is ~200-300 tokens, so 1024
#                   gives ~3-4x headroom. Larger wastes RAM/VRAM, smaller risks
#                   truncation on long subjects.
#   temperature   — 0.0 makes classification deterministic (same email → same
#                   verdict). Raise only if you want the model to be creative,
#                   which is generally not what you want for spam classification.
#   num_predict   — max output tokens. The JSON verdict is well under 100,
#                   so 200 is a safe cap that prevents runaway generations.
OLLAMA_NUM_CTX=1024
OLLAMA_TEMPERATURE=0.0
OLLAMA_NUM_PREDICT=200

# Maximum messages per audit run. The agent paginates Graph's @odata.nextLink
# up to this cap. Each surviving message is sent to Ollama, so audit time
# scales linearly: at concurrency 4 with ~3s per Ollama call, 200 messages ≈ 150s.
MAX_MESSAGES_PER_AUDIT=200

# Comma-separated sender domains whose mail is auto-deleted before classification.
# Subdomain matching is enabled — listing "example.com" also blocks "mail.example.com".
# Leave empty to disable. Uses the same Mail.ReadWrite scope as the manual Delete button.
BLOCKED_DOMAINS=
